{
  "name": "obsidian-table-enhancements",
  "version": "1.1.0",
  "description": "Per-table enhancements for Obsidian: hover row highlight and clickable checkboxes, opt-in via a marker comment.",
  "main": "main.js",
  "author": "Martín M.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skydiver/obsidian-table-enhancements.git"
  },
  "bugs": {
    "url": "https://github.com/skydiver/obsidian-table-enhancements/issues"
  },
  "homepage": "https://github.com/skydiver/obsidian-table-enhancements#readme",
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "tables",
    "checkbox"
  ],
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^22.19.19",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
